# ===== Shift Manager Auto - Environment Variables =====
# Copy file này thành .env rồi điền các giá trị thật

# URL của Supabase project (có sẵn, ít khi đổi)
SUPABASE_URL=https://qktvfncduxmoijzfqbdb.supabase.co

# Anon key của Supabase project
# Lấy: F12 -> Network -> click 1 request đến supabase.co -> Request Headers -> copy header "apikey"
SUPABASE_ANON_KEY=PASTE_ANON_JWT_HERE

# Member ID của bạn (UUID)
# Đây là field "sub" trong JWT access_token, hoặc lấy từ cookie sb-...-auth-token
MEMBER_ID=135fba41-2c8f-45e4-be00-7ef837930ed0

# Login để script tự tạo session riêng (cách khuyến nghị cho chạy tự động).
# Khi refresh token chết, script tự đăng nhập lại bằng email/password này.
EMAIL=you@example.com
PASSWORD=your_password

# (Tùy chọn) Refresh token ban đầu lấy từ browser cookie.
# Nếu đã có EMAIL/PASSWORD thì KHÔNG cần dòng này.
# INITIAL_REFRESH_TOKEN=PASTE_REFRESH_TOKEN_HERE

# (Tùy chọn) Đường dẫn file lưu state, mặc định ./.shift-state.json
# STATE_FILE=./.shift-state.json
